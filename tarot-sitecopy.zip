<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Таро</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#fff;--card-bg:#d8d7d5;--card-bg2:#cccbc9;
  --dark:#1d1d24;--dark2:#252532;
  --text:#0f0f0f;--text2:#555;--text3:#aaa;
  --sh-sm:0 1px 3px rgba(0,0,0,.08),0 0 0 1px rgba(0,0,0,.04);
  --sh-md:0 4px 16px rgba(0,0,0,.09),0 1px 4px rgba(0,0,0,.05);
  --sh-lg:0 20px 56px rgba(0,0,0,.13),0 4px 14px rgba(0,0,0,.07);
}
html,body{background:#fff;color:var(--text);font-family:'Inter',sans-serif;height:100%;margin:0;}
@keyframes breathe{0%,100%{opacity:.35}50%{opacity:1}}
@keyframes flyOut{0%{opacity:1}100%{transform:translate(-60vw,-120%) rotate(-20deg) scale(.2);opacity:0;}}

/* ── SHARED ── */
.flip-face{border-radius:13px;backface-visibility:hidden;overflow:hidden;box-shadow:var(--sh-lg);}
.card-back-face{background:url("data:image/png;base64,") center/cover no-repeat;display:flex;align-items:center;justify-content:center;}
.card-front-face{position:absolute;inset:0;transform:rotateY(180deg);background:var(--dark);display:flex;flex-direction:column;}
.back-inner{display:flex;flex-direction:column;align-items:center;gap:8px;}
.back-diamond{width:26px;height:26px;border:1.5px solid rgba(0,0,0,.35);transform:rotate(45deg);}
.back-label{font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:rgba(0,0,0,.45);font-weight:600;}
.card-art{flex:1;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--dark2);}
.card-art img{width:100%;height:100%;object-fit:cover;display:block;}
.card-art-empty{opacity:.15;}
.card-foot{padding:10px 14px 11px;display:flex;align-items:center;justify-content:space-between;background:rgba(8,8,14,.97);flex-shrink:0;}
.cfoot-name{font-size:9px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.7);}
.cfoot-num{font-size:12px;font-style:italic;color:rgba(255,255,255,.2);}

.idle-title{font-size:clamp(24px,3vw,38px);font-weight:700;letter-spacing:-.03em;color:var(--text);line-height:1.05;margin-bottom:8px;}
.idle-sub{font-size:13px;font-weight:300;line-height:1.75;color:var(--text2);max-width:340px;}
.idle-hint{margin-top:14px;font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);animation:breathe 3s ease-in-out infinite;}

/* INFO */
.info-block{width:100%;}
.info-tag{display:inline-block;font-size:11px;font-weight:500;color:var(--text3);margin-bottom:20px;}
.info-name-ru{font-size:12px;font-weight:400;color:var(--text3);margin-bottom:20px;}
.info-name{font-size:clamp(22px,2.6vw,34px);font-weight:700;letter-spacing:-.03em;color:var(--text);line-height:1.0;margin-bottom:4px;}
.info-keywords{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:28px;}
.info-kw{font-size:12px;font-weight:400;color:var(--text2);background:rgba(0,0,0,.05);border-radius:4px;padding:4px 10px;}
.info-section{margin-bottom:28px;}
.info-section-label{font-size:13px;font-weight:600;color:var(--text);margin-bottom:10px;}
.info-section-text{font-size:14px;font-weight:300;line-height:1.9;color:var(--text2);}
.info-section-text p{margin-bottom:10px;}
.info-section-text p:last-child{margin-bottom:0;}
.info-bullets{list-style:none;display:flex;flex-direction:column;gap:6px;}
.info-bullets li{font-size:14px;font-weight:300;line-height:1.7;color:var(--text2);}
.info-archetype{padding-top:20px;margin-top:8px;pointer-events:auto;}
.info-arch-text{font-size:12px;font-weight:400;color:var(--text3);font-style:italic;}
.story-link{color:var(--text2);text-decoration:underline;font-style:italic;cursor:pointer;pointer-events:auto;}
.story-link:hover{color:var(--text);}

/* FAN */
.fan-section{height:160px;display:flex;align-items:flex-end;justify-content:center;position:relative;padding:0 40px 0;overflow:hidden;border-top:1px solid rgba(0,0,0,.08);flex-shrink:0;background:#fff;}
.fan-hint{position:absolute;top:14px;left:50%;transform:translateX(-50%);font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--text2);white-space:nowrap;pointer-events:none;animation:breathe 3s ease-in-out infinite;transition:opacity .3s,transform .3s;}
.fan-hint.gone{opacity:0;transform:translateX(-50%) translateY(-4px);}
.reset-btn{position:absolute;top:12px;right:22px;background:var(--text);border:none;border-radius:100px;cursor:pointer;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:#fff;padding:8px 18px;box-shadow:var(--sh-md);transition:all .15s;opacity:0;pointer-events:none;}
.reset-btn.show{opacity:1;pointer-events:auto;}
.fan-wrap{position:relative;width:100%;height:150px;}
.fan-card{position:absolute;transform-origin:bottom center;cursor:pointer;border-radius:5px;background:linear-gradient(170deg,#2a3a4a 0%,#1a2530 100%);box-shadow:0 2px 8px rgba(0,0,0,.35),0 1px 2px rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.08);transition:filter .12s;will-change:transform;overflow:hidden;}
.fan-card:hover{filter:brightness(1.3);z-index:100!important;}
.fan-card:hover .clift{transform:translateY(-14px);}
.clift{width:100%;height:100%;transition:transform .14s;display:flex;align-items:center;justify-content:center;}
.clift-inner{display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;height:100%;}
.clift-diamond{display:none;}
.clift-line{display:none;}
.fan-card.flying{animation:flyOut .5s cubic-bezier(.4,0,.65,1) forwards;pointer-events:none;z-index:200!important;}
.fan-card.gone{display:none;}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(0,0,0,.06);flex-shrink:0;}
.nav-logo{font-size:11px;font-weight:700;color:var(--text);line-height:1.35;}
.nav-logo span{display:block;font-weight:300;color:var(--text2);font-size:10px;}
.seg{display:flex;background:rgba(0,0,0,.05);border-radius:12px;padding:3px;gap:1px;}
.seg-btn{background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--text2);border-radius:9px;transition:all .15s;white-space:nowrap;display:flex;align-items:center;gap:6px;}
.seg-btn:hover{color:var(--text);}
.seg-btn.active{background:#fff;color:var(--text);box-shadow:var(--sh-sm);}
.seg-badge{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;font-size:9px;font-weight:600;background:rgba(0,0,0,.07);color:var(--text2);transition:all .15s;}
.seg-btn.active .seg-badge{background:var(--text);color:#fff;}

footer a{font-size:11px;font-weight:400;letter-spacing:.04em;color:var(--text3);text-decoration:none;}
footer a:hover{color:var(--text2);}

/* ═══════════ DESKTOP ═══════════ */
#desktop-root{display:flex;flex-direction:column;height:100vh;overflow:hidden;}
#desktop-root nav{padding:12px 28px;}
#desktop-root .seg-btn{padding:7px 16px;}
#desktop-root footer{display:flex;align-items:center;justify-content:center;padding:6px 28px;flex-shrink:0;}
#desktop-root .fan-section{padding:0 64px 10px;}

.d-main{flex:1;min-height:0;height:0;display:flex;flex-direction:column;}
.d-view{display:none;flex:1;min-height:0;height:0;}
.d-view.active{display:grid;height:100%;}
.d-single{grid-template-columns:1fr 1fr;}
.d-spread{grid-template-columns:200px 1fr 1fr;}

.d-col-card{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px 28px;gap:14px;position:relative;overflow:hidden;min-height:0;align-self:stretch;}
.d-idle{display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;transition:opacity .3s,transform .3s;}
.d-idle.hidden{opacity:0;transform:translateY(-5px);position:absolute;pointer-events:none;}
.d-stage{display:none;flex-direction:column;align-items:center;gap:14px;width:100%;}
.d-stage.visible{display:flex;}
.d-flip{perspective:1100px;flex-shrink:0;}
.d-flip-inner{position:relative;transform-style:preserve-3d;transition:transform .85s cubic-bezier(.22,.1,.08,1);}
.d-flip.flipped .d-flip-inner{transform:rotateY(180deg);}
.d-col-info{display:flex;align-items:flex-start;overflow:hidden;min-height:0;}
.d-info{width:100%;height:100%;overflow-y:auto;padding:36px 48px 40px 40px;}
.d-info::-webkit-scrollbar{width:3px;}
.d-info::-webkit-scrollbar-thumb{background:rgba(0,0,0,.08);border-radius:2px;}

.d-col-list{padding:16px 8px 16px 20px;display:flex;flex-direction:column;justify-content:center;gap:6px;border-right:1px solid rgba(0,0,0,.05);overflow-y:auto;min-height:0;}
.sitem{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:11px;cursor:pointer;transition:background .15s;}
.sitem:hover{background:rgba(0,0,0,.03);}
.sitem.active{background:#fff;box-shadow:var(--sh-sm);}
.sthumb{flex-shrink:0;width:36px;height:60px;border-radius:6px;overflow:hidden;background:var(--card-bg);box-shadow:var(--sh-md);display:flex;flex-direction:column;transition:background .15s;}
.sitem.active .sthumb{background:var(--dark);}
.sthumb-art{flex:1;display:flex;align-items:center;justify-content:center;background:var(--card-bg2);}
.sitem.active .sthumb-art{background:var(--dark2);}
.sthumb-art img{width:100%;height:100%;object-fit:cover;}
.sthumb-bar{padding:2px 3px;text-align:center;background:rgba(0,0,0,.06);}
.sitem.active .sthumb-bar{background:rgba(0,0,0,.4);}
.sthumb-name{font-size:4.5px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(0,0,0,.4);}
.sitem.active .sthumb-name{color:rgba(255,255,255,.5);}
.sitem-pos{font-size:8px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:2px;}
.sitem.active .sitem-pos{color:var(--text2);}
.sitem-name{font-size:12px;font-weight:600;color:var(--text2);line-height:1.2;}
.sitem.active .sitem-name{color:var(--text);}
.sitem-waiting .sitem-name{font-weight:300;font-style:italic;color:var(--text3);}

.d-col-sc{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px 16px;border-right:1px solid rgba(0,0,0,.05);min-height:0;}
.d-sp-idle{display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;transition:opacity .3s;}
.d-sp-idle.hidden{opacity:0;pointer-events:none;position:absolute;}
.d-sflip{perspective:1100px;flex-shrink:0;}
.d-sflip-inner{position:relative;transform-style:preserve-3d;transition:transform .85s cubic-bezier(.22,.1,.08,1);}
.d-sflip.flipped .d-sflip-inner{transform:rotateY(180deg);}
.d-sp-info{width:100%;height:100%;overflow-y:auto;padding:36px 44px 40px 28px;}
.d-sp-info::-webkit-scrollbar{width:3px;}
.d-sp-info::-webkit-scrollbar-thumb{background:rgba(0,0,0,.08);border-radius:2px;}

/* ═══════════ MOBILE ═══════════ */
#mobile-root{display:flex;flex-direction:column;height:100vh;overflow:hidden;}
#mobile-root nav{padding:10px 16px;flex-direction:column;align-items:stretch;gap:8px;}
#mobile-root .seg{width:100%;justify-content:stretch;}
#mobile-root .seg-btn{flex:1;justify-content:center;padding:8px 4px;font-size:11px;}
#mobile-root .seg-badge{width:16px;height:16px;font-size:8px;}
#mobile-root footer{display:flex;align-items:center;justify-content:center;padding:6px 16px 10px;flex-shrink:0;}
#mobile-root .fan-section{height:160px;padding:0 12px 0;transition:transform .3s ease, opacity .3s ease;}
#mobile-root .fan-section.hidden{transform:translateY(100%);opacity:0;pointer-events:none;height:0;overflow:hidden;}
#mobile-root .fan-wrap{height:150px;}
#mobile-root .fan-hint{font-size:9px;top:9px;}
#mobile-root .reset-btn{font-size:9px;padding:5px 10px;top:7px;right:10px;}

.mob-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;}
.mob-scroll::-webkit-scrollbar{display:none;}

/* idle */
.mob-idle{display:flex;flex-direction:column;align-items:center;text-align:center;padding:32px 28px 16px;gap:8px;}

/* single card + info */
.mob-card-area{display:flex;flex-direction:column;align-items:center;padding:20px 24px 0;}
.mob-flip{perspective:1100px;}
.mob-flip-inner{position:relative;transform-style:preserve-3d;transition:transform .85s cubic-bezier(.22,.1,.08,1);}
.mob-flip.flipped .mob-flip-inner{transform:rotateY(180deg);}
.mob-info-area{padding:28px 20px 48px;width:100%;border-top:1px solid rgba(0,0,0,.07);}

/* spread strip */
.mob-strip-bar{display:flex;gap:6px;padding:10px 16px;border-bottom:1px solid rgba(0,0,0,.06);overflow-x:auto;-webkit-overflow-scrolling:touch;flex-shrink:0;}
.mob-strip-bar::-webkit-scrollbar{display:none;}
.mob-ss{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;padding:6px 8px;border-radius:8px;min-width:54px;transition:background .15s;}
.mob-ss.active{background:rgba(0,0,0,.05);}
.mob-ss-thumb{width:34px;height:58px;border-radius:5px;overflow:hidden;background:var(--card-bg);box-shadow:var(--sh-sm);display:flex;flex-direction:column;transition:background .15s;}
.mob-ss.filled .mob-ss-thumb{background:var(--dark);}
.mob-ss-art{flex:1;display:flex;align-items:center;justify-content:center;background:var(--card-bg2);}
.mob-ss.filled .mob-ss-art{background:var(--dark2);}
.mob-ss-art img{width:100%;height:100%;object-fit:cover;}
.mob-ss-bar{padding:2px;text-align:center;background:rgba(0,0,0,.06);}
.mob-ss.filled .mob-ss-bar{background:rgba(0,0,0,.4);}
.mob-ss-lbl{font-size:5px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(0,0,0,.4);}
.mob-ss.filled .mob-ss-lbl{color:rgba(255,255,255,.5);}
.mob-ss-pos{font-size:8px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);}
.mob-ss.active .mob-ss-pos{color:var(--text2);}

/* spread card + info */
.mob-sc-area{display:flex;flex-direction:column;align-items:center;padding:16px 24px 0;}
.mob-sflip{perspective:1100px;}
.mob-sflip-inner{position:relative;transform-style:preserve-3d;transition:transform .85s cubic-bezier(.22,.1,.08,1);}
.mob-sflip.flipped .mob-sflip-inner{transform:rotateY(180deg);}
.mob-sc-info{padding:28px 20px 48px;width:100%;border-top:1px solid rgba(0,0,0,.07);}



</style>
</head>
<body>

<!-- ═══ DESKTOP ═══ -->
<div id="desktop-root">
  <nav>
    <div class="nav-logo" onclick="setMode(1,document.querySelector('.seg-btn'))" style="cursor:pointer;">Tarot Cards<span>by katuy</span></div>
    <div class="seg">
      <button class="seg-btn active" onclick="setMode(1,this)">Одна карта <span class="seg-badge">I</span></button>
      <button class="seg-btn" onclick="setMode(3,this)">Три карты <span class="seg-badge">III</span></button>
      <button class="seg-btn" onclick="setMode(5,this)">Пять карт <span class="seg-badge">V</span></button>
      <button class="seg-btn" onclick="setMode(0,this)">Все карты</button>
    </div>
  </nav>
  <div class="d-main">
      <!-- Library view — same layout as dv-1 -->
  <div class="d-view d-single" id="dv-0">
      <div class="d-col-card">
        <div class="d-idle" id="d-lib-idle">
          <div class="idle-title">Библиотека карт.</div>
          <div class="idle-sub">Выбирай карты без&nbsp;ограничений. Каждая новая заменяет предыдущую.</div>
          <div class="idle-hint">↓ выбери карту ниже</div>
        </div>
        <div class="d-stage" id="d-lib-stage">
          <div class="d-flip" id="d-lib-flip">
            <div class="d-flip-inner" id="d-lib-fi">
              <div class="flip-face card-back-face" id="d-lib-fb"><div class="back-inner"><div class="back-diamond"></div><div class="back-label">Таро</div></div></div>
              <div class="flip-face card-front-face"><div class="card-art" id="d-lib-art"></div><div class="card-foot"><span class="cfoot-name" id="d-lib-cn"></span><span class="cfoot-num" id="d-lib-nn"></span></div></div>
            </div>
          </div>
        </div>
      </div>
      <div class="d-col-info"><div class="d-info" id="d-lib-info"></div></div>
    </div>

  <div class="d-view d-single active" id="dv-1">
      <div class="d-col-card">
        <div class="d-idle" id="d-idle">
          <div class="idle-title" id="d-t">Быстрый ответ.</div>
          <div class="idle-sub" id="d-s">Одна карта помогает остановиться и&nbsp;обратить внимание на&nbsp;то, что действительно важно прямо сейчас.</div>
          <div class="idle-hint">↓ выбери карту</div>
        </div>
        <div class="d-stage" id="d-stage">
          <div class="d-flip" id="d-flip">
            <div class="d-flip-inner" id="d-fi">
              <div class="flip-face card-back-face" id="d-fb"><div class="back-inner"><div class="back-diamond"></div><div class="back-label">Таро</div></div></div>
              <div class="flip-face card-front-face"><div class="card-art" id="d-art"></div><div class="card-foot"><span class="cfoot-name" id="d-cn"></span><span class="cfoot-num" id="d-nn"></span></div></div>
            </div>
          </div>
        </div>
      </div>
      <div class="d-col-info"><div class="d-info" id="d-info"></div></div>
    </div>
    <div class="d-view d-spread" id="dv-3">
      <div class="d-col-list" id="d-list"></div>
      <div class="d-col-sc">
        <div class="d-sp-idle" id="d-sp-idle">
          <div class="idle-title" id="d-sp-t" style="font-size:clamp(18px,2.2vw,26px);">Больше контекста.</div>
          <div class="idle-sub" id="d-sp-s" style="font-size:12px;max-width:200px;">Три карты раскрывают динамику ситуации.</div>
          <div class="idle-hint">↓ выбери карту</div>
        </div>
        <div class="d-sflip" id="d-sf" style="display:none;">
          <div class="d-sflip-inner" id="d-sfi">
            <div class="flip-face card-back-face" id="d-sfb"><div class="back-inner"><div class="back-diamond"></div><div class="back-label">Таро</div></div></div>
            <div class="flip-face card-front-face"><div class="card-art" id="d-sart"></div><div class="card-foot"><span class="cfoot-name" id="d-scn"></span><span class="cfoot-num" id="d-snn"></span></div></div>
          </div>
        </div>
      </div>
      <div class="d-col-info"><div class="d-sp-info" id="d-sinfo"></div></div>
    </div>
  </div>
  <div class="fan-section">
    <div class="fan-hint" id="d-fhint">Выбери карту</div>
    <div class="fan-wrap" id="d-fan"></div>
    <button class="reset-btn" id="d-reset" onclick="doReset()">↺&thinsp;Заново</button>
  </div>
  <footer><a href="https://t.me/thatscene_katuy" target="_blank">© katuy</a></footer>
</div>

<!-- ═══ MOBILE ═══ -->
<div id="mobile-root" style="display:none;">
  <nav>
    <div class="nav-logo" onclick="setMode(1,document.querySelector('.seg-btn'))" style="cursor:pointer;">Tarot Cards<span>by katuy</span></div>
    <div class="seg">
      <button class="seg-btn active" onclick="setMode(1,this)">Одна карта <span class="seg-badge">I</span></button>
      <button class="seg-btn" onclick="setMode(3,this)">Три карты <span class="seg-badge">III</span></button>
      <button class="seg-btn" onclick="setMode(5,this)">Пять карт <span class="seg-badge">V</span></button>
      <button class="seg-btn" onclick="setMode(0,this)">Все карты</button>
    </div>
  </nav>

  <!-- scrollable body -->
  <div class="mob-scroll" id="mob-scroll">

    <!-- single: idle -->
    <div id="m-idle"><div class="mob-idle">
      <div class="idle-title" id="m-t">Быстрый ответ.</div>
      <div class="idle-sub" id="m-s">Одна карта помогает остановиться и&nbsp;обратить внимание на&nbsp;то, что действительно важно прямо сейчас.</div>
      <div class="idle-hint" style="margin-top:12px;">↓ выбери карту ниже</div>
    </div></div>

    <!-- single: card + info -->
    <div id="m-card" style="display:none;">
      <div class="mob-card-area">
        <div class="mob-flip" id="m-flip">
          <div class="mob-flip-inner" id="m-fi">
            <div class="flip-face card-back-face" id="m-fb"><div class="back-inner"><div class="back-diamond"></div><div class="back-label">Таро</div></div></div>
            <div class="flip-face card-front-face"><div class="card-art" id="m-art"></div><div class="card-foot"><span class="cfoot-name" id="m-cn"></span><span class="cfoot-num" id="m-nn"></span></div></div>
          </div>
        </div>
      </div>
