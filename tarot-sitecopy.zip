  {"name": "KNIGHT OF PENTACLES", "num": "", "name_ru": "Рыцарь Пентаклей", "char": "Драко", "univ": "Двадцать пятый/Нулевой", "art": "https://res.cloudinary.com/dxiewnsr9/image/upload/v1779038625/75_knight_of_pentacles_sy8obo.webp", "story_link": "https://ficbook.net/readfic/01975843-c5c2-7dcd-a03f-cfa4882eff1b", "keywords": ["Стабильность", "Надёжность", "Терпение", "Рутина"], "meaning": "Рыцарь Пентаклей двигается медленно, но почти никогда не бросает начатое. Карта дисциплины, повторяющихся действий и способности продолжать даже тогда, когда мотивация давно закончилась. Иногда в этом есть сила. Иногда — ощущение, что жизнь превратилась только в обязанности и выживание по расписанию. В ней много устойчивости и внутренней усталости одновременно.", "if_now": "Похоже, ты слишком долго жила только через “надо”, забывая спрашивать себя, чего тебе вообще хочется.", "attention": ["эмоциональную монотонность", "усталость от рутины", "желание всё контролировать через порядок", "необходимость замедлиться"], "relations": "Надёжность, стабильность и привязанность, которая выражается через поступки, а не громкие эмоции.", "work": "Очень сильная карта для долгосрочной работы, ответственности и медленного, но устойчивого роста."},
  {"name": "QUEEN OF PENTACLES", "num": "", "name_ru": "Королева Пентаклей", "char": "", "univ": "", "art": "https://res.cloudinary.com/dxiewnsr9/image/upload/v1779038625/76_queen_of_pentacles_euiin2.webp", "story_link": "", "keywords": ["Забота", "Комфорт", "Стабильность", "Тепло"], "meaning": "Королева Пентаклей умеет создавать пространство, в котором становится спокойнее жить. Эта карта связана с заботой, практичностью и вниманием к вещам, которые делают жизнь устойчивее и мягче. Иногда она появляется у людей, которые слишком долго заботились обо всех вокруг и почти забыли о себе. В ней много спокойной силы и внутреннего тепла.", "if_now": "Похоже, тебе самой сейчас нужна та забота, которую ты обычно отдаёшь другим.", "attention": ["собственное состояние", "желание уюта и безопасности", "эмоциональное переутомление", "необходимость замедлиться и восстановиться"], "relations": "Тепло, забота и ощущение, что рядом с человеком можно расслабиться и быть собой.", "work": "Хорошая карта для стабильности, материального роста и проектов, связанных с красотой, домом или заботой о людях."},
  {"name": "KING OF PENTACLES", "num": "", "name_ru": "Король Пентаклей", "char": "Драко", "univ": "Нервный срыв Гермионы Грейнджер", "art": "https://res.cloudinary.com/dxiewnsr9/image/upload/v1779038626/77_king_og_pentacles_oczn4s.webp", "story_link": "https://ficbook.net/readfic/019df99a-7f78-7f72-8e2d-3b15d17b737c", "keywords": ["Стабильность", "Контроль", "Надёжность", "Результат"], "meaning": "Король Пентаклей связан с ощущением опоры и способности удерживать жизнь в стабильном состоянии даже под давлением. Это карта человека, который привык брать ответственность на себя и строить что-то долгосрочное. Иногда за этой устойчивостью скрывается сильная усталость и невозможность позволить себе расслабиться. В нём много спокойствия, контроля и внутренней тяжести одновременно.", "if_now": "Похоже, ты слишком долго несёшь на себе всё молча, потому что привыкла быть “надёжной”.", "attention": ["давление ответственности", "желание всё держать под контролем", "усталость от постоянной стабильности", "необходимость заботиться не только о других, но и о себе"], "relations": "Надёжность, желание строить будущее и человек, который показывает любовь через действия и ответственность.", "work": "Очень сильная карта для финансовой устойчивости, серьёзных решений и долгосрочного успеха."},
];
const DECK=Array.from({length:78},(_,i)=>i<REAL.length?REAL[i]:{name:`CARD ${i+1}`,num:`${i+1}`,char:"—",univ:"—",art:null,name_ru:`Карта ${i+1}`,...PH});
const POS3=["Прошлое","Настоящее","Будущее"],POS5=["Ситуация","Прошлое","Будущее","Причина","Итог"];
const TITLES={0:"Библиотека карт.",1:"Быстрый ответ.",3:"Больше контекста.",5:"Когда нужен полный расклад."};
const SUBS={0:"Все 78 карт — без ограничений. Выбирай сколько угодно.",1:"Одна карта помогает остановиться и\u00a0обратить внимание на\u00a0то, что действительно важно прямо сейчас.",3:"Три карты раскрывают динамику ситуации — что сформировало её, где ты находишься сейчас и\u00a0что может быть дальше.",5:"Для сложных вопросов и\u00a0моментов, в\u00a0которых хочется увидеть картину целиком."};

let mode=1, drawn=0, spreadCards=[], mobSpreadCards=[];
const isMob=()=>window.innerWidth<=680;

// ── INIT: show correct root ───────────────────────────────────
function initLayout(){
  const mob=isMob();
  document.getElementById('desktop-root').style.display=mob?'none':'flex';
  document.getElementById('mobile-root').style.display=mob?'flex':'none';
}
initLayout();

// ── HELPERS ──────────────────────────────────────────────────
const EMPTY_ART=`<div class="card-art-empty"><svg width="28" height="42" viewBox="0 0 28 42" fill="none"><rect x="10" y="0" width="8" height="8" transform="rotate(45 14 4)" stroke="rgba(255,255,255,.35)" stroke-width="1" fill="none"/><line x1="14" y1="8" x2="14" y2="34" stroke="rgba(255,255,255,.15)" stroke-width="1"/><rect x="10" y="34" width="8" height="8" transform="rotate(45 14 38)" stroke="rgba(255,255,255,.35)" stroke-width="1" fill="none"/></svg></div>`;
function setArt(id,card){const e=document.getElementById(id);if(!e)return;e.innerHTML=card.art?`<img src="${card.art}" alt="">`:EMPTY_ART;}

function buildArch(card) {
  if(!card.char && !card.univ) return '';
  let parts = [];
  if(card.char) parts.push(card.char);
  let univHtml = '';
  if(card.univ) {
    if(card.story_link) {
      univHtml = '<a href="' + card.story_link + '" target="_blank" rel="noopener" class="story-link">' + card.univ + '</a>';
    } else {
      univHtml = card.univ;
    }
    parts.push(univHtml);
  }
  return '<div class="info-archetype"><div class="info-arch-text">' + parts.join(' · ') + '</div></div>';
}

function renderInfo(card,id){
  const ib=document.getElementById(id);if(!ib)return;
  const kw=card.keywords||[];
  const kwH=kw.length?`<div class="info-keywords">${kw.map(k=>`<span class="info-kw">${k}</span>`).join('')}</div>`:'';
  const sec=(lbl,txt)=>txt?`<div class="info-section"><div class="info-section-label">${lbl}</div><div class="info-section-text">${txt.split('\n').filter(Boolean).map(p=>`<p>${p}</p>`).join('')}</div></div>`:'';
  const bul=(lbl,items)=>items&&items.length?`<div class="info-section"><div class="info-section-label">${lbl}</div><ul class="info-bullets">${items.map(a=>`<li>${a}</li>`).join('')}</ul></div>`:'';
  // Archetype: char · univ — always at bottom
  const arch=[card.char&&card.char!=='—'?card.char:'',card.univ&&card.univ!=='—'?card.univ:''].filter(Boolean).join(' · ');
  ib.innerHTML=`
    <div class="info-name">${card.name}</div>
    ${card.name_ru?`<div class="info-name-ru">${card.name_ru}</div>`:''}
    ${kwH}
    ${sec('Общее значение',card.meaning)}
    ${card.if_now?`<div class="info-section"><div class="info-section-label">Если карта выпала тебе сейчас</div><div class="info-section-text"><p>${card.if_now}</p></div></div>`:''}
    ${bul('На что обратить внимание',card.attention)}
    ${sec('В отношениях',card.relations)}
    ${sec('В работе и деньгах',card.work)}
    ${buildArch(card)}
  `;
}

// ── CARD SIZING ───────────────────────────────────────────────
function sizeDeskSingle(){
  const el=document.querySelector('#dv-1 .d-col-card');if(!el)return;
  const h=Math.min(el.clientHeight-56,(el.clientWidth-56)*1.7,400);
  const w=Math.max(Math.round(h/1.7),130),hh=Math.max(Math.round(h),220);
  ['d-flip','d-fi','d-fb'].forEach(id=>{const e=document.getElementById(id);if(e){e.style.width=w+'px';e.style.height=hh+'px';}});
}
function sizeDeskSpread(){
  const el=document.querySelector('.d-col-sc');if(!el)return;
  const h=Math.min(el.clientHeight-40,(el.clientWidth-32)*1.7,380);
  const w=Math.max(Math.round(h/1.7),110),hh=Math.max(Math.round(h),188);
  ['d-sf','d-sfi','d-sfb'].forEach(id=>{const e=document.getElementById(id);if(e){e.style.width=w+'px';e.style.height=hh+'px';}});
}
function sizeMobSingle(){
  const vw=window.innerWidth;
  const w=Math.min(Math.round(vw*.80),320),h=Math.round(w*1.7);
  ['m-flip','m-fi','m-fb'].forEach(id=>{const e=document.getElementById(id);if(e){e.style.width=w+'px';e.style.height=h+'px';}});
}
function sizeMobSpread(){
  const vw=window.innerWidth;
  const w=Math.min(Math.round(vw*.65),260),h=Math.round(w*1.7);
  ['m-sflip','m-sfi','m-sfb'].forEach(id=>{const e=document.getElementById(id);if(e){e.style.width=w+'px';e.style.height=h+'px';}});
}

// ── FAN ───────────────────────────────────────────────────────
function buildFan(){
  const mob=isMob();
  const wrapId=mob?'m-fan':'d-fan';
  const wrap=document.getElementById(wrapId);if(!wrap)return;
  wrap.innerHTML='';
  const CW=mob?44:52,CH=mob?75:88;
  const wW=wrap.clientWidth||window.innerWidth-(mob?32:128);
  const spreadW=wW*0.96;
  const shuffled=[...Array(78).keys()].sort(()=>Math.random()-.5);
  shuffled.forEach((ci,i)=>{
    // Each card: bottom always at 0, spaced evenly, just rotated
    const bx=(wW-spreadW)/2+(spreadW/77)*i;
    const pct=(bx-wW/2)/(wW/2); // -1 to +1
    const angle=pct*22; // max ±22 degrees at edges
    const el=document.createElement('div');
    el.className='fan-card';
    el.style.cssText=`width:${CW}px;height:${CH}px;left:${bx-CW/2}px;bottom:0;transform:rotate(${angle}deg);z-index:${i}`;
    el.innerHTML=`<div class="clift"><div class="clift-inner"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1L13 7L7 13L1 7Z" stroke="rgba(255,255,255,0.3)" stroke-width="1" fill="rgba(255,255,255,0.06)"/></svg></div></div>`;
    el.onclick=()=>pickCard(el,ci);
    wrap.appendChild(el);
  });
}

// ── DESKTOP LOGIC ─────────────────────────────────────────────
function deskSingle(card){
  document.getElementById('d-idle').classList.add('hidden');
  const st=document.getElementById('d-stage');st.classList.add('visible');
  sizeDeskSingle();
  setArt('d-art',card);
  document.getElementById('d-cn').textContent=card.name;
  document.getElementById('d-nn').textContent=card.num;
  setTimeout(()=>{document.getElementById('d-flip').classList.add('flipped');setTimeout(()=>renderInfo(card,'d-info'),500);},120);
}
function initDeskList(){
  const list=document.getElementById('d-list');list.innerHTML='';
  const pos=mode===3?POS3:POS5;
  for(let i=0;i<mode;i++){
    const item=document.createElement('div');
    item.className='sitem sitem-waiting';item.id=`dsi-${i}`;
    item.innerHTML=`<div class="sthumb"><div class="sthumb-art">${EMPTY_ART.replace(/rgba\(255,255,255,.35\)/g,'rgba(0,0,0,.2)').replace(/rgba\(255,255,255,.15\)/g,'rgba(0,0,0,.12)')}</div><div class="sthumb-bar"><span class="sthumb-name">${pos[i]}</span></div></div><div><div class="sitem-pos">${pos[i]}</div><div class="sitem-name">Ждёт тебя</div></div>`;
    list.appendChild(item);
  }
}
const SVG_DARK=`<svg width="14" height="22" viewBox="0 0 14 22" fill="none"><rect x="5" y="0" width="4" height="4" transform="rotate(45 7 2)" stroke="rgba(255,255,255,.3)" stroke-width=".8" fill="none"/><line x1="7" y1="4" x2="7" y2="18" stroke="rgba(255,255,255,.15)" stroke-width=".8"/><rect x="5" y="18" width="4" height="4" transform="rotate(45 7 20)" stroke="rgba(255,255,255,.3)" stroke-width=".8" fill="none"/></svg>`;
function updateDeskList(card,idx){
  const pos=mode===3?POS3:POS5;
  const item=document.getElementById(`dsi-${idx}`);if(!item)return;
  item.classList.remove('sitem-waiting');item.onclick=()=>deskSelectSpread(idx);
  const a=card.art?`<img src="${card.art}" style="width:100%;height:100%;object-fit:cover">`:SVG_DARK;
  item.innerHTML=`<div class="sthumb"><div class="sthumb-art">${a}</div><div class="sthumb-bar"><span class="sthumb-name">${card.name}</span></div></div><div><div class="sitem-pos">${pos[idx]}</div><div class="sitem-name">${card.name_ru||card.name}</div></div>`;
}
function deskSelectSpread(idx){
  spreadCards.forEach((_,i)=>{const s=document.getElementById(`dsi-${i}`);if(s){s.classList.toggle('active',i===idx);s.classList.toggle('inactive',i!==idx);}});
  const card=spreadCards[idx];if(!card)return;
  document.getElementById('d-sp-idle').classList.add('hidden');
  const sf=document.getElementById('d-sf');sf.style.display='block';
  sizeDeskSpread();
  setArt('d-sart',card);
  document.getElementById('d-scn').textContent=card.name;
  document.getElementById('d-snn').textContent=card.num;
  const root=document.getElementById('d-sf');root.classList.remove('flipped');void root.offsetWidth;
  setTimeout(()=>{root.classList.add('flipped');setTimeout(()=>renderInfo(card,'d-sinfo'),500);},60);
}

// ── MOBILE LOGIC ──────────────────────────────────────────────
function mobSingle(card){
  document.getElementById('m-idle').style.display='none';
  document.getElementById('m-card').style.display='block';
  requestAnimationFrame(()=>{
    sizeMobSingle();
    setArt('m-art',card);
    document.getElementById('m-cn').textContent=card.name;
    document.getElementById('m-nn').textContent=card.num;
    const _mfl=document.getElementById('m-flip');if(_mfl)_mfl.classList.remove('flipped');
    setTimeout(()=>{
      document.getElementById('m-flip').classList.add('flipped');
      setTimeout(()=>{
        renderInfo(card,'m-info');
        
      },500);
    },300);
  });
}
let mobSpread=[];
function initMobStrip(){
  mobSpread=[];
  const strip=document.getElementById('m-strip');
  strip.style.display='flex';strip.innerHTML='';
  document.getElementById('m-sp-idle').style.display='block';
  document.getElementById('m-sc').style.display='none';
  const pos=mode===3?POS3:POS5;
  for(let i=0;i<mode;i++){
    const sl=document.createElement('div');
    sl.className='mob-ss';sl.id=`mss-${i}`;
    sl.innerHTML=`<div class="mob-ss-thumb"><div class="mob-ss-art"><svg width="14" height="22" viewBox="0 0 14 22" fill="none"><rect x="5" y="0" width="4" height="4" transform="rotate(45 7 2)" stroke="rgba(0,0,0,.2)" stroke-width=".8" fill="none"/><line x1="7" y1="4" x2="7" y2="18" stroke="rgba(0,0,0,.12)" stroke-width=".8"/><rect x="5" y="18" width="4" height="4" transform="rotate(45 7 20)" stroke="rgba(0,0,0,.2)" stroke-width=".8" fill="none"/></svg></div><div class="mob-ss-bar"><span class="mob-ss-lbl">${pos[i]}</span></div></div><div class="mob-ss-pos">${pos[i]}</div>`;
    strip.appendChild(sl);
  }
  const titles={1:"Быстрый ответ.",3:"Больше контекста.",5:"Когда нужен полный расклад."};
  const subs={1:"",3:"Три карты раскрывают динамику ситуации.",5:"Для сложных вопросов."};
  const st=document.getElementById('m-sp-t');if(st)st.textContent=titles[mode];
  const ss=document.getElementById('m-sp-s');if(ss)ss.textContent=subs[mode];
  requestAnimationFrame(()=>sizeMobSpread());
}
function mobAddCard(card,idx){
  mobSpread[idx]=card;
  const pos=mode===3?POS3:POS5;
  const sl=document.getElementById(`mss-${idx}`);if(!sl)return;
  sl.classList.add('filled');
  const a=card.art?`<img src="${card.art}" style="width:100%;height:100%;object-fit:cover">`:SVG_DARK;
  sl.innerHTML=`<div class="mob-ss-thumb"><div class="mob-ss-art">${a}</div><div class="mob-ss-bar"><span class="mob-ss-lbl">${card.name}</span></div></div><div class="mob-ss-pos">${pos[idx]}</div>`;
  sl.onclick=()=>mobSelectSpread(idx);
  mobSelectSpread(idx);
}
function mobSelectSpread(idx){
  document.querySelectorAll('.mob-ss').forEach((s,i)=>s.classList.toggle('active',i===idx));
  const card=mobSpread[idx];if(!card)return;
  document.getElementById('m-sp-idle').style.display='none';
  document.getElementById('m-sc').style.display='block';
  requestAnimationFrame(()=>{
    sizeMobSpread();
    setArt('m-sart',card);
    document.getElementById('m-scn').textContent=card.name;
    document.getElementById('m-snn').textContent=card.num;
    const root=document.getElementById('m-sflip');
    root.classList.remove('flipped');void root.offsetWidth;
    setTimeout(()=>{
      root.classList.add('flipped');
      setTimeout(()=>{
        renderInfo(card,'m-sinfo');
        
      },500);
    },100);
  });
}


// ── LIBRARY MODE ──────────────────────────────────────────────
function deskLibReveal(card) {
  const idle = document.getElementById('d-lib-idle');
  if(idle) idle.classList.add('hidden');
  const st = document.getElementById('d-lib-stage');
  if(st) st.classList.add('visible');
  // Size — use dv-0 col-card specifically
  const el = document.querySelector('#dv-0 .d-col-card') || document.getElementById('dv-0');
  if(el) {
    const h = Math.min(el.clientHeight-56, (el.clientWidth-56)*1.7, 400);
    const w = Math.max(Math.round(h/1.7),130), hh = Math.max(Math.round(h),220);
    ['d-lib-flip','d-lib-fi','d-lib-fb'].forEach(id=>{const e=document.getElementById(id);if(e){e.style.width=w+'px';e.style.height=hh+'px';}});
  }
  setArt('d-lib-art', card);
  document.getElementById('d-lib-cn').textContent = card.name;
  document.getElementById('d-lib-nn').textContent = card.num;
  const flip = document.getElementById('d-lib-flip');
  if(!flip) return;
  flip.classList.remove('flipped');
  void flip.offsetWidth;
  const info = document.getElementById('d-lib-info');
  if(info){ info.innerHTML=''; info.classList.remove('visible'); }
  setTimeout(() => {
    flip.classList.add('flipped');
    setTimeout(() => renderInfo(card, 'd-lib-info'), 500);
  }, 80);
}

function mobLibReveal(card) {
  document.getElementById('m-lib-idle').style.display = 'none';
  document.getElementById('m-lib-card').style.display = 'block';
  requestAnimationFrame(() => requestAnimationFrame(() => {
    sizeMobSingle();
    // Use lib flip elements
    const vw = window.innerWidth;
    const w = Math.min(Math.round(vw*.80),320), h = Math.round(w*1.7);
    ['m-lib-flip','m-lib-fi','m-lib-fb'].forEach(id=>{const e=document.getElementById(id);if(e){e.style.width=w+'px';e.style.height=h+'px';}});

    setArt('m-lib-art', card);
    document.getElementById('m-lib-cn').textContent = card.name;
    document.getElementById('m-lib-nn').textContent = card.num;
    const flip = document.getElementById('m-lib-flip');
    flip.classList.remove('flipped');
    void flip.offsetWidth;
    document.getElementById('m-lib-info').innerHTML = '';
    // Scroll to top of card
    const ms = document.getElementById('mob-scroll');
    if(ms) ms.scrollTop = 0;
    setTimeout(() => {
      flip.classList.add('flipped');
      setTimeout(() => renderInfo(card, 'm-lib-info'), 500);
    }, 300);
  }));
}
// ── PICK CARD ─────────────────────────────────────────────────
function pickCard(el,ci){
  if(el.classList.contains('flying')||el.classList.contains('gone'))return;
  if(mode===1&&drawn>=1)return;
  if(mode>1&&drawn>=mode)return;
  // Library: no limit, rebuild fan after each pick
  if(mode===0){
    el.classList.add('flying');
    el.addEventListener('animationend',()=>{
      el.classList.add('gone');
      // Rebuild fan so there are always cards to pick
      setTimeout(()=>buildFan(),100);
    },{once:true});
    const fhint=document.getElementById(isMob()?'m-fhint':'d-fhint');
    if(fhint)fhint.classList.add('gone');
    const card=DECK[ci];
    if(isMob()) setTimeout(()=>mobLibReveal(card),260);
    else setTimeout(()=>deskLibReveal(card),260);
    return;
  }
  drawn++;
  el.classList.add('flying');
  el.addEventListener('animationend',()=>el.classList.add('gone'),{once:true});
  const fhint=document.getElementById(isMob()?'m-fhint':'d-fhint');
  if(fhint)fhint.classList.add('gone');
  const card=DECK[ci];
  if(isMob()){
    if(mode===1)setTimeout(()=>mobSingle(card),260);
    else{const idx=drawn-1;mobSpread[idx]=card;setTimeout(()=>mobAddCard(card,idx),260);}
  } else {
    if(mode===1)setTimeout(()=>deskSingle(card),260);
    else{const idx=drawn-1;spreadCards[idx]=card;setTimeout(()=>{updateDeskList(card,idx);deskSelectSpread(idx);},260);}
  }
  if(drawn>=mode){
    const rb=document.getElementById(isMob()?'m-reset':'d-reset');
    if(rb)setTimeout(()=>rb.classList.add('show'),700);
  }
}

// ── SET MODE ──────────────────────────────────────────────────
function setMode(m,btn){
  document.querySelectorAll('.seg-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  mode=m;

  // ── Fix 3: titles use TITLES, subs use SUBS correctly ──
  const titleIds=['d-t','m-t'];
  const subIds=['d-s','m-s'];
  const spTitleIds=['d-sp-t','m-sp-t'];
  const spSubIds=['d-sp-s','m-sp-s'];
  [...titleIds,...spTitleIds].forEach(id=>{
    const e=document.getElementById(id);
    if(e){e.style.opacity='0';setTimeout(()=>{e.textContent=TITLES[m]||'';e.style.opacity='1';},200);}
  });
  [...subIds,...spSubIds].forEach(id=>{
    const e=document.getElementById(id);
    if(e){e.style.opacity='0';setTimeout(()=>{e.textContent=SUBS[m]||'';e.style.opacity='1';},200);}
  });

  // ── Show/hide fan ──
  const dFan=document.querySelector('#desktop-root .fan-section');
  const mFan=document.querySelector('#mobile-root .fan-section');
  if(dFan) dFan.style.display='';
  if(mFan) mFan.style.display='';

  // ── Fix 2: always hide ALL views before showing the right one ──
  ['dv-0','dv-1','dv-3'].forEach(id=>{
    const e=document.getElementById(id);if(e)e.classList.remove('active');
  });

  if(m===0){
    // Library mode
    drawn=0; spreadCards=[]; mobSpread=[];
    const dv0=document.getElementById('dv-0');if(dv0)dv0.classList.add('active');
    const dli=document.getElementById('d-lib-idle');if(dli)dli.classList.remove('hidden');
    const dls=document.getElementById('d-lib-stage');if(dls)dls.classList.remove('visible');
    const dlf=document.getElementById('d-lib-flip');if(dlf)dlf.classList.remove('flipped');
    const dlinf=document.getElementById('d-lib-info');if(dlinf)dlinf.innerHTML='';
    // Mobile
    const ms=document.getElementById('mob-scroll');if(ms)ms.scrollTop=0;
    ['m-idle','m-card','m-sc','m-sp-idle','m-lib-card'].forEach(id=>{
      const e=document.getElementById(id);if(e)e.style.display='none';
    });
    const mstrip=document.getElementById('m-strip');if(mstrip)mstrip.style.display='none';
    const mli=document.getElementById('m-lib-idle');if(mli)mli.style.display='block';
    const mli2=document.getElementById('m-lib-card');if(mli2)mli2.style.display='none';
    const mh=document.getElementById('m-fhint');if(mh)mh.classList.remove('gone');
    const dh=document.getElementById('d-fhint');if(dh)dh.classList.remove('gone');
    const mr=document.getElementById('m-reset');if(mr)mr.classList.remove('show');
    const dr=document.getElementById('d-reset');if(dr)dr.classList.remove('show');
    buildFan();
  } else {
    doReset();
  }
}

// ── RESET ─────────────────────────────────────────────────────
function doReset(){
  drawn=0;spreadCards=[];mobSpread=[];

  // Desktop
  document.getElementById('dv-1').classList.toggle('active',mode===1);
  document.getElementById('dv-3').classList.toggle('active',mode>1);
  const di=document.getElementById('d-idle');if(di)di.classList.remove('hidden');
  const ds=document.getElementById('d-stage');if(ds)ds.classList.remove('visible');
  const df=document.getElementById('d-flip');if(df)df.classList.remove('flipped');
  const dinfo=document.getElementById('d-info');if(dinfo)dinfo.innerHTML='';
  if(mode>1)initDeskList();
  const dspi=document.getElementById('d-sp-idle');if(dspi)dspi.classList.remove('hidden');
  const dsf=document.getElementById('d-sf');if(dsf){dsf.style.display='none';dsf.classList.remove('flipped');}
  const dsi=document.getElementById('d-sinfo');if(dsi)dsi.innerHTML='';

  // Mobile scroll to top
  const ms=document.getElementById('mob-scroll');if(ms)ms.scrollTop=0;
  // Show/hide mobile sections
  // Always hide lib sections on reset
  const mli=document.getElementById('m-lib-idle');if(mli)mli.style.display='none';
  const mlc=document.getElementById('m-lib-card');if(mlc)mlc.style.display='none';
  const mlinfo=document.getElementById('m-lib-info');if(mlinfo)mlinfo.innerHTML='';
  const mlflip=document.getElementById('m-lib-flip');if(mlflip)mlflip.classList.remove('flipped');
  const mi=document.getElementById('m-idle');if(mi)mi.style.display=mode===1?'block':'none';
  const mc=document.getElementById('m-card');if(mc){mc.style.display='none';const mf=document.getElementById('m-flip');if(mf)mf.classList.remove('flipped');}
  const mif=document.getElementById('m-info');if(mif)mif.innerHTML='';
  const mspi=document.getElementById('m-sp-idle');
  const msc=document.getElementById('m-sc');
  const mstrip=document.getElementById('m-strip');
  if(mode>1){if(mspi)mspi.style.display='none';if(msc)msc.style.display='none';if(mstrip)mstrip.style.display='none';initMobStrip();}
  else{if(mspi)mspi.style.display='none';if(msc)msc.style.display='none';if(mstrip)mstrip.style.display='none';}
  const msi=document.getElementById('m-sinfo');if(msi)msi.innerHTML='';

  const dr=document.getElementById('d-reset');if(dr)dr.classList.remove('show');
  const mr=document.getElementById('m-reset');if(mr)mr.classList.remove('show');
  const dh=document.getElementById('d-fhint');if(dh)dh.classList.remove('gone');
  const mh=document.getElementById('m-fhint');if(mh)mh.classList.remove('gone');
  buildFan();
}


// ── MOBILE SCROLL HIDE/SHOW FAN ───────────────────────────────
let lastScrollY = 0;
function initMobScroll(){
  const scrollEl = document.getElementById('mob-scroll');
  if(!scrollEl) return;
  scrollEl.addEventListener('scroll', ()=>{
    // Hide entire bottom block (fan + footer) when scrolling down
    const fanSection = document.querySelector('#mobile-root .fan-section');
    const footer = document.querySelector('#mobile-root footer');
    const y = scrollEl.scrollTop;
    const goingDown = y > lastScrollY && y > 40;
    if(fanSection) fanSection.classList.toggle('hidden', goingDown);
    if(footer){
      footer.style.transition='opacity .3s';
      footer.style.opacity = goingDown ? '0' : '1';
      footer.style.pointerEvents = goingDown ? 'none' : '';
    }
    lastScrollY = y;
  }, {passive:true});
}

initMobScroll();



doReset();
window.addEventListener('resize',()=>{
  initLayout();
  buildFan();
  if(!isMob())sizeDeskSingle();
});
</script>

    <div class="wiki-modal-body">
      <div class="wiki-modal-art" id="wiki-modal-art"></div>
      <div class="wiki-modal-info" id="wiki-modal-info"></div>
    </div>
  </div>
</div>
</body>
</html>
